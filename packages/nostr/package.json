{
  "name": "@hashden/nostr",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./relays": {
      "types": "./src/relays.ts",
      "default": "./src/relays.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no linter configured yet'",
    "test": "tsx --test src/**/*.test.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "nostr-tools": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3"
  }
}
