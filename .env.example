# Hashden — example env vars
# Copy to .env and fill in. .env is gitignored.

# === Postgres (matches infrastructure/docker-compose.yml dev defaults) ===
DATABASE_URL=postgresql://hashden:hashden_dev@localhost:5432/hashden_dev

# === Redis ===
REDIS_URL=redis://localhost:6380

# === Bitcoin RPC ===
# Point at any Bitcoin Core / Knots node reachable from this machine.
# Mainnet defaults: RPC 8332, ZMQ rawblock 28332, ZMQ hashblock 28333.
# (Umbrel exposes the same node on non-default ports 9332 / 48332 / 48334 — adjust if that's your setup.)
BITCOIN_RPC_URL=http://127.0.0.1:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_ZMQ_RAWBLOCK=tcp://127.0.0.1:28332
BITCOIN_ZMQ_HASHBLOCK=tcp://127.0.0.1:28333

# === Stratum ===
STRATUM_PORT=3333
STRATUM_API_PORT=3334

# === Platform identity ===
# Hashden signing key for block-found events (kind 1) + zap receipts (kind 9735).
# Accepts either bech32 (`npub1…` / `nsec1…`) or 64-char hex. Same key on both vars.
PROJECT_NPUB=
PROJECT_NSEC=
# Platform's cold BTC address — appears in every coinbase as the platform-fee output.
PLATFORM_BTC_ADDRESS=
# Operator-fee basis points (cap on what an operator can charge on top of platform fee).
PLATFORM_FEE_BPS=50

# === Operator credential encryption ===
# 32 bytes hex; generate with `openssl rand -hex 32`. Used to encrypt operator
# LNbits admin keys / NWC URIs at rest.
OPERATOR_CREDS_ENC_KEY=

# === Nostr relays ===
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net

# === Web app ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3334
NEXT_PUBLIC_STRATUM_URL=stratum+tcp://localhost:3333

# === Dust threshold for PPLNS coinbase split (sats) ===
# Members whose computed payout falls below this threshold are bundled into
# the operator's dust-bucket coinbase output and fanned out via Lightning.
DUST_THRESHOLD_SATS=10000
