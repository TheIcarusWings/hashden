{
  "name": "hashden",
  "private": true,
  "version": "0.0.0",
  "description": "Marketplace of Bitcoin solo-mining groups with Nostr-native identity, discovery, and payouts",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "secp256k1",
      "tiny-secp256k1",
      "zeromq",
      "sqlite3",
      "sharp",
      "@nestjs/core"
    ],
    "overrides": {
      "form-data@<2.5.4": "^2.5.5",
      "tar": "^7.5.11",
      "path-to-regexp@<3.3.0": "^3.3.0",
      "lodash@<4.18.0": "^4.18.0"
    }
  }
}
