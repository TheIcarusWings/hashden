# bitcoin node running in your private network 192.168.1.0/24
BITCOIN_RPC_URL=http://192.168.1.100

# bitcoin node running undockered on the same PC
# needs to add rpcallowip=172.16.0.0/12 to your bitcoin.conf
#BITCOIN_RPC_URL=http://host.docker.internal

BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_TIMEOUT=10000

# You can use this instead of BITCOIN_RPC_USER and BITCOIN_RPC_PASSWORD
BITCOIN_RPC_COOKIEFILE=

# Enable in bitcoin.conf with
# zmqpubrawblock=tcp://*:3000
# BITCOIN_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=3334
STRATUM_PORT=3333

# Bytes of extranonce2 the miner generates (advertised in mining.subscribe).
# Default 8 -> compatible with hashrate marketplaces (Braiins requires >=7,
# NiceHash >=8). Set to 4 to restore the historical upstream public-pool value.
# Must stay <= 16 (kept inside the 100-byte coinbase scriptSig limit).
EXTRANONCE2_SIZE=8

# Vardiff (variable difficulty) tuning.
# Target spacing between accepted shares, in seconds (default 10). Larger =
# fewer, harder shares per connection.
#VARDIFF_TARGET_SECONDS_PER_SHARE=10
# Grace window (ms, default 30000) after a difficulty increase during which
# shares that only clear the previous (lower) target are still accepted and
# credited at that lower difficulty. Cuts the share-reject ratio that hashrate
# marketplaces (Braiins, NiceHash) use to cancel/blacklist orders. Set 0 to
# restore strict immediate rejection.
#VARDIFF_GRACE_MS=30000

#optional telegram bot
#TELEGRAM_BOT_TOKEN=

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional
DEV_FEE_ADDRESS=
# mainnet | testnet
NETWORK=mainnet

API_SECURE=false
# Default is "Public-Pool", you can change it to any string it will be removed if it will make the block or coinbase script too big
POOL_IDENTIFIER="Public-Pool"
