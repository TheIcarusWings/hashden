{
  "name": "@hashden/payouts",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no linter configured yet'",
    "test": "tsx --test src/**/*.test.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hashden/crypto": "workspace:*",
    "@hashden/db": "workspace:*",
    "@hashden/nostr": "workspace:*",
    "@hashden/shared": "workspace:*",
    "@hashden/templates": "workspace:*",
    "nostr-tools": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3"
  }
}
